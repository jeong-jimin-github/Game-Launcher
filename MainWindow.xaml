<Window x:Class="GameLauncherWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SubarashiiGame Launcher"
        Width="946"
        Height="646"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">
    <Window.Resources>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" EndPoint="1,1" StartPoint="0,0">
            <GradientStop Color="#FFFFCF4A" Offset="0" />
            <GradientStop Color="#FFF8A90B" Offset="1" />
        </LinearGradientBrush>

    </Window.Resources>

    <Border CornerRadius="20" BorderBrush="#44FFFFFF" BorderThickness="1" ClipToBounds="True">
        <Grid TextElement.FontFamily="Segoe UI Variable Display">
            <Grid.Background>
                <RadialGradientBrush RadiusX="1.4" RadiusY="1.2" Center="0.85,0.1" GradientOrigin="0.85,0.1">
                    <GradientStop Color="#FF2B3247" Offset="0" />
                    <GradientStop Color="#FF111520" Offset="0.55" />
                    <GradientStop Color="#FF0B0E14" Offset="1" />
                </RadialGradientBrush>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#22000000" MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="48" />
                </Grid.ColumnDefinitions>

                <TextBlock Margin="20,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#FFF2F2F2"
                           Text="SubarashiiGame Launcher" />

                <Button Grid.Column="1"
                        Click="OnCloseClicked"
                        Content="✕"
                        FontSize="15"
                        Foreground="#FFF5F5F5"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand" />
            </Grid>

            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="18" Background="#40000000" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Foreground="#FFEAEAF0" FontSize="26" FontWeight="Bold" Text="Kuuhaku" />
                            <TextBlock Margin="0,-4,0,0" Foreground="#99FFFFFF" FontSize="24" FontWeight="Bold" Text="Games" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,30,0,0">
                            <Border CornerRadius="10" Background="#33FFFFFF" Padding="12,10">
                                <TextBlock Foreground="#FFF8F8FA" FontWeight="SemiBold" Text="Home" />
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="3"
                                CornerRadius="12"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                Background="#22000000"
                                ClipToBounds="True">
                            <Grid>
                                <Image Source="pack://application:,,,/Assets/GameThumbnail.png"
                                       Stretch="UniformToFill" />
                                <Border VerticalAlignment="Bottom" Background="#88000000" Padding="8,6">
                                    <TextBlock Foreground="#FFF4F4F6"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="Subarashii Game" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" CornerRadius="18" Background="#26000000" Padding="28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#FFF5F6FA" FontSize="34" FontWeight="Bold" Text="SubarashiiGame" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,6,0,0"
                                   Foreground="#B3FFFFFF"
                                   FontSize="16"
                                   Text="최신 빌드를 다운로드하고 바로 플레이하세요." />

                        <Border Grid.Row="2" Margin="0,28,0,0" CornerRadius="12" Background="#50000000" Padding="16">
                            <TextBlock Foreground="#FFF2F2F2"
                                       FontSize="16"
                                       TextWrapping="Wrap"
                                       Text="{Binding StatusMessage}" />
                        </Border>

                        <StackPanel Grid.Row="4" Orientation="Vertical">
                            <Border CornerRadius="9" Height="16" Background="#55000000" BorderBrush="#33FFFFFF" BorderThickness="1">
                                <Grid>
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding ProgressPercent, Mode=OneWay}"
                                                 Foreground="{StaticResource PrimaryButtonBrush}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Height="14"
                                                 Margin="1" />
                                </Grid>
                            </Border>

                            <Button Margin="0,18,0,0"
                                    Height="62"
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="#FFFFFFFF"
                                    Content="{Binding ActionButtonText}"
                                    Command="{Binding PrimaryActionCommand}"
                                    Background="{Binding ActionButtonBrush}"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
