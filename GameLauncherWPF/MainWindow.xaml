<Window x:Class="GameLauncherWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Launcher" Height="520" Width="700"
        MinHeight="420" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Game List -->
        <GroupBox Grid.Row="0" Header="My Games" Margin="0,0,0,8">
            <ListBox x:Name="GameListBox"
                     SelectionChanged="GameListBox_SelectionChanged"
                     DisplayMemberPath="Name"
                     Margin="4"/>
        </GroupBox>

        <!-- Add / Edit Game Form -->
        <GroupBox Grid.Row="1" Header="Game Details" Margin="0,0,0,8">
            <Grid Margin="8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Name:"/>
                <TextBox x:Name="NameTextBox"
                         Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Path:"/>
                <TextBox x:Name="PathTextBox"
                         Grid.Row="2" Grid.Column="1"/>
                <Button Grid.Row="2" Grid.Column="2" Content="Browse…"
                        Click="Browse_Click" Margin="6,0,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Add / Update" Click="AddGame_Click"/>
            <Button Content="Remove" Click="RemoveGame_Click"/>
            <Button Content="▶  Launch Game" Click="LaunchGame_Click"
                    Background="#27AE60" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
