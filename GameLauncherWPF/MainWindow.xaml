<Window x:Class="GameLauncherWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SubarashiiGame Launcher"
        Width="946" Height="646"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C">

    <Window.Resources>
        <!-- Transparent button style for sidebar items -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="5,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCCC3333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Yellow action button style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#80FFCC00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#CCFFCC00"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#66888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Progress bar with yellow fill -->
        <Style x:Key="YellowProgressBar" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#33000000" CornerRadius="3">
                            <Border x:Name="PART_Track" CornerRadius="3">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="#FFCC00"
                                        CornerRadius="3"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root grid -->
    <Grid>
        <!-- ① Background image (fills window) -->
        <Image x:Name="BackgroundImage"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- ② Dark left panel overlay (matches Python's black rectangle opacity 0.3 + left sidebar) -->
        <Border Width="240"
                HorizontalAlignment="Left"
                Background="#CC000000"/>

        <!-- ③ Left panel content -->
        <DockPanel Width="240"
                   HorizontalAlignment="Left"
                   LastChildFill="False">

            <!-- Top: branding + nav -->
            <StackPanel DockPanel.Dock="Top" Margin="0,28,0,0">
                <TextBlock Text="Kuuhaku"
                           FontFamily="Segoe UI"
                           FontWeight="Bold"
                           FontSize="28"
                           Foreground="White"
                           Margin="30,0,0,0"/>
                <TextBlock Text="Games"
                           FontFamily="Segoe UI"
                           FontWeight="Bold"
                           FontSize="28"
                           Foreground="White"
                           Margin="30,0,0,6"/>

                <!-- Separator -->
                <Rectangle Height="1" Fill="#60FFFFFF" Margin="25,6,25,6"/>

                <!-- Home button -->
                <Button Style="{StaticResource SidebarButtonStyle}"
                        Margin="15,0,15,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏠" FontSize="14" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Home" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Separator -->
                <Rectangle Height="1" Fill="#60FFFFFF" Margin="25,6,25,6"/>
            </StackPanel>

            <!-- Bottom: Discord button -->
            <Button DockPanel.Dock="Bottom"
                    Style="{StaticResource SidebarButtonStyle}"
                    Click="Discord_Click"
                    Margin="15,0,15,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💬" FontSize="14" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="디스코드 서버" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </DockPanel>

        <!-- ④ Drag region (top 50 px, avoids close button on right) -->
        <Border Height="50"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Margin="0,0,50,0"
                Background="Transparent"
                MouseLeftButtonDown="DragRegion_MouseLeftButtonDown"/>

        <!-- ⑤ Close button (top-right) -->
        <Button Style="{StaticResource CloseButtonStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Content="✕"
                Click="Close_Click"/>

        <!-- ⑥ Bottom action bar (right of left panel) -->
        <Border VerticalAlignment="Bottom"
                Margin="240,0,0,0"
                Height="80"
                Background="#D9000000">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- Info text + progress bar -->
                <StackPanel Grid.Column="0"
                            Margin="20,10,10,10"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="InfoText"
                               Text=""
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis"/>
                    <ProgressBar x:Name="ProgressBar"
                                 Style="{StaticResource YellowProgressBar}"
                                 Height="10"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Margin="0,6,0,0"
                                 Visibility="Collapsed"/>
                </StackPanel>

                <!-- Action button -->
                <Button x:Name="ActionButton"
                        Grid.Column="1"
                        Style="{StaticResource ActionButtonStyle}"
                        Content="다운로드"
                        Margin="10,12,15,12"
                        Click="Action_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
